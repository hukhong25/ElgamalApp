<Window x:Class="ElgamalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElgamalApp"
        mc:Ignorable="d"
        Title="Phần mềm chữ ký số Elgamal - Nhóm 2 - WPF" Height="700" Width="1000" WindowStartupLocation="CenterScreen">


    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="TẠO KHÓA" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" Foreground="#1A237E"/>

                    <Label Content="Khóa công khai (p, g, y):"/>
                    <Label Content="Số nguyên tố p =" FontWeight="Normal" Margin="10,2,0,0"/>
                    <TextBox Name="txtP" Height="28"/>

                    <Label Content="Phần tử nguyên thủy g =" FontWeight="Normal" Margin="10,0,0,0"/>
                    <TextBox Name="txtG" Height="28"/>

                    <Label Content="Khóa công khai y =" FontWeight="Normal" Margin="10,0,0,0"/>
                    <TextBox Name="txtY" Height="28" IsReadOnly="True"/>

                    <Label Content="Khóa bí mật (x):" Margin="0,5,0,0"/>
                    <Label Content="Số nguyên x =" FontWeight="Normal" Margin="10,2,0,0"/>
                    <TextBox Name="txtX" Height="28"/>

                    <Button Content="Tạo khóa ngẫu nhiên (512-bit)" Height="38" Margin="0,15,0,5" Click="BtnGenerateKeys_Click"/>
                    <Button Content="Tính khóa Y (Nếu tự nhập tay p,g,x)" Height="32" Margin="0,0,0,5" Click="BtnCalculateY_Click" Background="#3182CE"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Lưu khóa" Height="32" Click="BtnSaveKey_Click"/>
                        <Button Grid.Column="1" Content="Chuyển tiếp khóa" Height="32" Click="BtnForwardKey_Click"/>
                    </Grid>

                    <Button Content="Reset dữ liệu" Height="32" Margin="0,5,0,0" Click="BtnReset_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="KÝ VĂN BẢN" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" Foreground="#1A237E"/>

                    <Label Content="Chọn file để mở nội dung:"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Mở file" Width="65" Height="28" Click="BtnOpenFileToSign_Click"/>
                        <TextBox Name="txtFilePathSign" IsReadOnly="True" Height="28" Margin="0,0,5,0" Background="#F0F0F0"/>
                    </DockPanel>

                    <Label Content="Nội dung văn bản (Gõ tay hoặc tải từ file):" Margin="0,5,0,0"/>
                    <TextBox Name="txtInputTextSign" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" Margin="0,2,0,5"/>

                    <Button Content="Lưu nội dung ra file" Height="28" Margin="0,0,0,10" Click="BtnSaveFileSign_Click" Background="#4A5568" Foreground="White"/>

                    <Label Content="Nội dung chữ ký (r, s):"/>
                    <TextBox Name="txtSignResult" Height="65" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#F0F0F0"/>

                    <Button Content="Ký văn bản" Height="38" Margin="0,15,0,5" Click="BtnSignData_Click"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Chuyển tiếp dữ liệu" Height="32" Click="BtnForwardData_Click"/>
                        <Button Grid.Column="1" Content="Lưu file chữ ký" Height="32" Click="BtnSaveSignature_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="12" Margin="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="XÁC MINH CHỮ KÝ" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" Foreground="#1A237E"/>

                    <Label Content="Chọn file văn bản cần kiểm tra:"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Mở file" Width="65" Height="28" Click="BtnOpenFileToVerify_Click"/>
                        <TextBox Name="txtFilePathVerify" IsReadOnly="True" Height="28" Margin="0,0,5,0" Background="#F0F0F0"/>
                    </DockPanel>

                    <Label Content="Nội dung văn bản:" Margin="0,5,0,0"/>
                    <TextBox Name="txtInputTextVerify" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" Margin="0,2,0,5"/>

                    <Label Content="Thông số khóa xác thực:" Margin="0,5,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="p=" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Name="txtVerifyP" Grid.Column="1" Height="26"/>
                        <TextBlock Grid.Column="2" Text="g=" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Name="txtVerifyG" Grid.Column="3" Height="26"/>
                        <TextBlock Grid.Column="4" Text="y=" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Name="txtVerifyY" Grid.Column="5" Height="26"/>
                    </Grid>

                    <Label Content="Đường dẫn file Khóa công khai:" Margin="0,5,0,0" FontSize="11" Foreground="#718096"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="File Khóa" Width="80" Height="28" Click="BtnLoadKey_Click"/>
                        <TextBox Name="txtKeyPathVerify" IsReadOnly="True" Height="28" Margin="0,0,5,0" Background="#F0F0F0"/>
                    </DockPanel>

                    <Label Content="Đường dẫn file chữ ký số:" Margin="0,5,0,0" FontSize="11" Foreground="#718096"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="File chữ ký" Width="80" Height="28" Click="BtnLoadSignature_Click"/>
                        <TextBox Name="txtSigPathVerify" IsReadOnly="True" Height="28" Margin="0,0,5,0" Background="#F0F0F0"/>
                    </DockPanel>

                    <Label Content="Nội dung chữ ký cần kiểm tra (r, s):" Margin="0,5,0,0"/>
                    <TextBox Name="txtVerifySignData" Height="65" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <Button Content="Xác minh chữ ký" Height="38" Margin="0,15,0,5" Click="BtnVerify_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
